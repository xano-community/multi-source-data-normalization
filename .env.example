# Multi-Source Data Normalization API — required environment variables.
# Set these on the Xano workspace (Settings -> Environment Variables). All eleven are required.

# External Postgres (native db.external.postgres connector)
POSTGRES_CONNECTION_STRING=postgresql://user:password@host:5432/dbname

# Snowflake SQL API v2 (bearer-token auth — PASSWORD carries the Programmatic Access Token)
SNOWFLAKE_ACCOUNT=https://your-org-your-account.snowflakecomputing.com
SNOWFLAKE_USERNAME=YOUR_SNOWFLAKE_USER
SNOWFLAKE_PASSWORD=your-programmatic-access-token
SNOWFLAKE_DATABASE=YOUR_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=YOUR_WH
SNOWFLAKE_ROLE=YOUR_ROLE

# Salesforce REST API
SALESFORCE_INSTANCE_URL=https://yourco.my.salesforce.com
SALESFORCE_ACCESS_TOKEN=your-salesforce-oauth-bearer-token

# Shared secret required on every endpoint via the X-API-Secret header
API_AUTH_SECRET=choose-a-long-random-secret
